{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pip install -r work/requirements.txt",
    "watchPatterns": [
      "work/**"
    ]
  },
  "deploy": {
    "startCommand": "cd work && gunicorn app:app --bind 0.0.0.0:$PORT --workers 2 --timeout 120",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}