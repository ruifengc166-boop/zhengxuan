# === 必填配置 ===
# 生产环境必须改成足够随机的长密钥，例如：python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-this-to-a-long-random-secret
APP_ENV=production

# 后台填写模型 API Key 时使用。建议与 JWT_SECRET 不同。
API_KEY_ENCRYPTION_SECRET=change-this-to-another-long-random-secret

# === 服务配置 ===
PORT=3000
JWT_EXPIRE_HOURS=24
FLASK_DEBUG=0
MAX_UPLOAD_MB=500

# === 跨域配置 ===
# 多个域名用英文逗号分隔；本地演示可使用 *
CORS_ORIGINS=*

# === 初始化管理员 ===
ADMIN_PHONE=18800000000
# 不设置 ADMIN_PASSWORD 时，setup.py 会自动生成强密码
# ADMIN_PASSWORD=
ADMIN_NAME=系统管理员
ORG_NAME=默认组织
ORG_SHORT_NAME=默认

# === 模型供应商配置：未配置后台 API Key 时，才会读取这些环境变量 ===
TEXT_PROVIDER=openai
TEXT_MODEL=gpt-4o
OPENAI_API_KEY=

IMAGE_PROVIDER=openai
IMAGE_MODEL=dall-e-3

VIDEO_PROVIDER=kling
VIDEO_MODEL=kling-1.6
KLING_API_KEY=
